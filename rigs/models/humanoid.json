{
  "$schema": "paper-rig/model-1",
  "family": "humanoid",
  "base": true,
  "slots": [
    {
      "id": "nearGripSlot",
      "type": "hand.grip",
      "owner": { "kind": "joint", "id": "nearHand" },
      "localFrame": {
        "positionMeters": [0.08, 0, 0],
        "rotationXYZDegrees": [0, 0, 0]
      },
      "scaleBehavior": "preserve-local-aspect",
      "cardinality": 1,
      "counterpartSlotId": "farGripSlot"
    },
    {
      "id": "farGripSlot",
      "type": "hand.grip",
      "owner": { "kind": "joint", "id": "farHand" },
      "localFrame": {
        "positionMeters": [0.08, 0, 0],
        "rotationXYZDegrees": [0, 0, 0]
      },
      "scaleBehavior": "preserve-local-aspect",
      "cardinality": 1,
      "counterpartSlotId": "nearGripSlot"
    },
    {
      "id": "headgearSlot",
      "type": "head.hat",
      "owner": { "kind": "joint", "id": "head" },
      "localFrame": {
        "positionMeters": [0, 0, 0.22],
        "rotationXYZDegrees": [0, 0, 0]
      },
      "scaleBehavior": "preserve-local-aspect",
      "cardinality": 1
    },
    {
      "id": "leftEyeDetailSlot",
      "type": "face.eye.detail",
      "owner": { "kind": "plate", "id": "leftEyePlate" },
      "localFrame": {
        "positionMeters": [0.012, 0.012, 0.005],
        "rotationXYZDegrees": [0, 0, 0]
      },
      "scaleBehavior": "preserve-local-aspect",
      "cardinality": 1,
      "region": {
        "kind": "box",
        "centerMeters": [0, 0, 0.005],
        "sizeMeters": [0.06, 0.06, 0.02]
      }
    }
  ],
  "attachments": [
    {
      "id": "simpleSword",
      "moduleId": "simpleSword",
      "slotId": "nearGripSlot",
      "scale": 1
    },
    {
      "id": "travelPack",
      "moduleId": "travelPack",
      "slotId": "backAnchor",
      "scale": 1
    },
    {
      "id": "simpleHat",
      "moduleId": "simpleHat",
      "slotId": "headgearSlot",
      "scale": 0.8
    },
    {
      "id": "leftEyeGlint",
      "moduleId": "eyeGlint",
      "slotId": "leftEyeDetailSlot",
      "scale": 1
    }
  ],
  "clips": {
    "attack": {
      "base": "idleA",
      "duration": 620,
      "easing": "cubic-bezier(.2,.8,.2,1)",
      "loop": false,
      "frames": [
        {
          "t": 0,
          "poses": {},
          "rotations": {}
        },
        {
          "t": 0.62,
          "poses": {},
          "rotations": {
            "nearShoulder": [
              0,
              -25,
              -70
            ],
            "nearElbow": [
              0,
              10,
              70
            ]
          }
        },
        {
          "t": 1,
          "poses": {},
          "rotations": {}
        }
      ],
      "contacts": [
        "nearFoot",
        "farFoot"
      ],
      "events": [
        {
          "t": 0.62,
          "name": "impact"
        },
        {
          "t": 0.83,
          "name": "release"
        }
      ],
      "boneLengthPolicy": "preserve",
      "motionSemantics": "joint-local rotation; no child-bone translation"
    }
  },
  "motion": {
    "$schema": "paper-rig/motion-plan-1",
    "clips": {
      "attack": {
        "recipe": "wholeBodyStrike",
        "duration": 720,
        "layers": [
          {
            "id": "rootWeightShift",
            "block": "weightShift",
            "transform": { "poses": { "root": [0, 0.06, 0] } }
          },
          {
            "id": "stanceTurn",
            "block": "stance",
            "transform": { "rotations": { "hips": [0, 0, 10] } }
          },
          {
            "id": "torsoSwing",
            "block": "bodyDrive",
            "transform": { "rotations": { "spine": [0, 0, -18], "shoulders": [0, 0, -12] } }
          },
          {
            "id": "leadArmSwing",
            "block": "strike",
            "transform": { "rotations": { "nearShoulder": [0, -25, -70], "nearHand": [0, 0, -15] } }
          },
          {
            "id": "leadArmFlex",
            "block": "flex",
            "transform": { "rotations": { "nearElbow": [0, 10, 70] } }
          }
        ],
        "contacts": ["nearFoot", "farFoot"]
      }
    }
  },
  "appearance": {
    "$schema": "paper-rig/appearance-plan-1",
    "instances": [
      {
        "id": "faceBlaze",
        "primitiveId": "faceBlaze",
        "ownerPlateId": "headPlate",
        "surfaceFrame": {
          "tangent": [0, 1, 0],
          "bitangent": [0, 0, 1],
          "normal": [1, 0, 0]
        },
        "region": { "center": [0, 0], "size": [0.4, 1.2] },
        "transform": {
          "translate": [0, 0.05],
          "rotateDegrees": 0,
          "scale": [0.7, 0.72]
        }
      }
    ]
  },
  "plateOverrides": [
    {
      "match": "^(?:pelvisSpinePlate|chestPlate|shoulderPlate|neckPlate|headConnectorPlate|headPlate|(?:near|far)(?:Thigh|Shin|Foot|Bicep|Forearm|Hand|ShoulderCap)Plate)$",
      "set": {
        "semanticDetailTier": "silhouette"
      }
    },
    {
      "match": "^(?:leftEyePlate|rightEyePlate|nosePlate)$",
      "set": {
        "semanticDetailTier": "expression"
      }
    },
    {
      "id": "castShadow",
      "set": {
        "semanticDetailTier": "texture"
      }
    }
  ]
}
