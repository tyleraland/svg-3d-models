{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:paper-rig:schema:model-1",
  "title": "paper-rig declarative model source",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "family"],
  "properties": {
    "$schema": { "const": "paper-rig/model-1" },
    "family": { "$ref": "#/$defs/id" },
    "base": { "type": "boolean" },
    "variant": { "$ref": "#/$defs/variant" },
    "limbs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upper", "lower", "paw"],
      "properties": {
        "upper": { "$ref": "#/$defs/positiveNumber" },
        "lower": { "$ref": "#/$defs/positiveNumber" },
        "paw": { "$ref": "#/$defs/size" }
      }
    },
    "plateSizeOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["match", "size"],
        "properties": {
          "match": { "type": "string", "minLength": 1 },
          "size": { "$ref": "#/$defs/size" }
        }
      }
    },
    "addons": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/pairedEarsAddon" },
          { "$ref": "#/$defs/muzzleAddon" }
        ]
      }
    },
    "clipEvents": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/event" }
      }
    },
    "clips": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/clip" }
    },
    "clipPatches": {
      "type": "array",
      "items": { "$ref": "#/$defs/clipPatch" }
    },
    "attachments": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachmentInstance" }
    },
    "slots": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachmentSlot" }
    },
    "motion": { "$ref": "#/$defs/motionPlan" },
    "attack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rotations"],
      "properties": {
        "rotations": { "$ref": "#/$defs/transformMap" },
        "opts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "impact": { "$ref": "#/$defs/time" },
            "events": { "type": "array", "items": { "$ref": "#/$defs/event" } }
          }
        }
      }
    },
    "gait": {
      "type": "object",
      "additionalProperties": false,
      "required": ["a", "b"],
      "properties": {
        "a": { "$ref": "#/$defs/transformMap" },
        "b": { "$ref": "#/$defs/transformMap" },
        "semantics": { "type": "string", "minLength": 1 }
      }
    },
    "occlusion": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["match", "mode"],
        "properties": {
          "match": { "type": "string", "minLength": 1 },
          "mode": { "$ref": "#/$defs/occlusionMode" },
          "reference": {
            "oneOf": [
              { "$ref": "#/$defs/id" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["ifMatch", "then", "else"],
                "properties": {
                  "ifMatch": { "type": "string", "minLength": 1 },
                  "then": { "$ref": "#/$defs/id" },
                  "else": { "$ref": "#/$defs/id" }
                }
              }
            ]
          }
        }
      }
    },
    "plateOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["set"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "match": { "type": "string", "minLength": 1 },
          "set": { "$ref": "#/$defs/platePatch" }
        },
        "oneOf": [
          { "required": ["id"], "properties": { "id": { "$ref": "#/$defs/id" }, "match": false } },
          { "required": ["match"], "properties": { "id": false, "match": { "type": "string", "minLength": 1 } } }
        ]
      }
    },
    "anchorOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "set"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "set": { "$ref": "#/$defs/anchorPatch" }
        }
      }
    }
  },
  "oneOf": [
    { "required": ["base"], "properties": { "base": { "const": true }, "variant": false } },
    { "required": ["variant"], "properties": { "base": false, "variant": { "$ref": "#/$defs/variant" } } }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
    "finiteNumber": { "type": "number" },
    "positiveNumber": { "type": "number", "exclusiveMinimum": 0 },
    "time": { "type": "number", "minimum": 0, "maximum": 1 },
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/finiteNumber" }
    },
    "size": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/positiveNumber" }
    },
    "transformMap": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/vector3" }
    },
    "nonEmptyTransformMap": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/vector3" }
    },
    "clipPatchAdd": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "poses": { "$ref": "#/$defs/nonEmptyTransformMap" },
        "rotations": { "$ref": "#/$defs/nonEmptyTransformMap" }
      }
    },
    "clipPatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clip", "t", "add"],
      "properties": {
        "clip": { "$ref": "#/$defs/id" },
        "t": { "$ref": "#/$defs/time" },
        "add": { "$ref": "#/$defs/clipPatchAdd" }
      }
    },
    "attachmentInstance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "moduleId", "slotId"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "moduleId": { "$ref": "#/$defs/id" },
        "slotId": { "$ref": "#/$defs/id" },
        "scale": { "$ref": "#/$defs/positiveNumber" }
      }
    },
    "attachmentSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "owner", "localFrame", "scaleBehavior", "cardinality"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "$ref": "#/$defs/slotType" },
        "owner": { "$ref": "#/$defs/slotOwner" },
        "localFrame": { "$ref": "#/$defs/attachmentFrame" },
        "scaleBehavior": { "enum": ["inherit-owner-scale", "preserve-local-aspect"] },
        "cardinality": { "type": "integer", "minimum": 1 },
        "counterpartSlotId": { "$ref": "#/$defs/id" },
        "region": { "$ref": "#/$defs/attachmentRegion" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "owner": {
                "type": "object",
                "properties": { "kind": { "const": "plate" } },
                "required": ["kind"]
              }
            }
          },
          "then": {
            "type": "object",
            "properties": { "region": { "$ref": "#/$defs/attachmentRegion" } },
            "required": ["region"]
          }
        }
      ]
    },
    "slotType": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9]*)*$" },
    "slotOwner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["joint", "plate"] },
        "id": { "$ref": "#/$defs/id" }
      }
    },
    "attachmentFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["positionMeters", "rotationXYZDegrees"],
      "properties": {
        "positionMeters": { "$ref": "#/$defs/vector3" },
        "rotationXYZDegrees": { "$ref": "#/$defs/vector3" }
      }
    },
    "attachmentRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "centerMeters", "sizeMeters"],
      "properties": {
        "kind": { "const": "box" },
        "centerMeters": { "$ref": "#/$defs/vector3" },
        "sizeMeters": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/positiveNumber" }
        }
      }
    },
    "motionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "clips"],
      "properties": {
        "$schema": { "const": "paper-rig/motion-plan-1" },
        "clips": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "$ref": "#/$defs/motionClip" }
        }
      }
    },
    "motionClip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recipe", "layers"],
      "properties": {
        "recipe": { "$ref": "#/$defs/id" },
        "base": { "$ref": "#/$defs/id" },
        "duration": { "$ref": "#/$defs/positiveNumber" },
        "easing": { "type": "string", "minLength": 1 },
        "loop": { "type": "boolean" },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/motionLayer" }
        },
        "contacts": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
        "contactIntervals": { "type": "array", "items": { "$ref": "#/$defs/contactInterval" } }
      }
    },
    "motionLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "block", "transform"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "block": { "$ref": "#/$defs/id" },
        "transform": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "poses": { "$ref": "#/$defs/nonEmptyTransformMap" },
            "rotations": { "$ref": "#/$defs/nonEmptyTransformMap" }
          }
        }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t"],
      "properties": {
        "t": { "$ref": "#/$defs/time" },
        "poses": { "$ref": "#/$defs/transformMap" },
        "rotations": { "$ref": "#/$defs/transformMap" }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t", "name"],
      "properties": {
        "t": { "$ref": "#/$defs/time" },
        "name": { "type": "string", "minLength": 1 },
        "phase": { "$ref": "#/$defs/id" }
      }
    },
    "contactInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ids", "from", "to"],
      "properties": {
        "ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
        "from": { "$ref": "#/$defs/time" },
        "to": { "$ref": "#/$defs/time" }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "duration", "easing", "loop", "frames"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "aliasOf": { "$ref": "#/$defs/id" },
        "base": { "$ref": "#/$defs/id" },
        "duration": { "$ref": "#/$defs/positiveNumber" },
        "easing": { "type": "string", "minLength": 1 },
        "loop": { "type": "boolean" },
        "frames": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/frame" } },
        "contacts": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
        "contactIntervals": { "type": "array", "items": { "$ref": "#/$defs/contactInterval" } },
        "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
        "phases": { "type": "array", "minItems": 4, "maxItems": 5, "items": { "$ref": "#/$defs/motionPhase" } },
        "motionRecipe": { "$ref": "#/$defs/motionRecipeReference" },
        "boneLengthPolicy": { "type": "string", "minLength": 1 },
        "motionSemantics": { "type": "string", "minLength": 1 }
      }
    },
    "motionPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "peak", "to"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "from": { "$ref": "#/$defs/time" },
        "peak": { "$ref": "#/$defs/time" },
        "to": { "$ref": "#/$defs/time" }
      }
    },
    "motionRecipeReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "recipeId", "recipeVersion", "layers"],
      "properties": {
        "schema": { "const": "paper-rig/motion-resolution/1" },
        "recipeId": { "$ref": "#/$defs/id" },
        "recipeVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "block"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "block": { "$ref": "#/$defs/id" }
            }
          }
        }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "archetypes", "height", "scale"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "archetypes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "height": { "$ref": "#/$defs/positiveNumber" },
        "scale": { "$ref": "#/$defs/positiveNumber" },
        "groundY": { "$ref": "#/$defs/finiteNumber" },
        "sx": { "$ref": "#/$defs/positiveNumber" },
        "sy": { "$ref": "#/$defs/positiveNumber" },
        "sz": { "$ref": "#/$defs/positiveNumber" },
        "thickness": { "$ref": "#/$defs/positiveNumber" },
        "profile": { "type": "object", "additionalProperties": true },
        "jointTweaks": { "$ref": "#/$defs/transformMap" },
        "plateTweaks": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "$ref": "#/$defs/size" }
        }
      }
    },
    "pairedEarsAddon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "pairedEars" },
        "baseX": { "$ref": "#/$defs/finiteNumber" },
        "baseY": { "$ref": "#/$defs/finiteNumber" },
        "baseZ": { "$ref": "#/$defs/finiteNumber" },
        "tipX": { "$ref": "#/$defs/finiteNumber" },
        "tipY": { "$ref": "#/$defs/finiteNumber" },
        "tipZ": { "$ref": "#/$defs/finiteNumber" },
        "width": { "$ref": "#/$defs/positiveNumber" },
        "style": { "type": "string", "minLength": 1 }
      }
    },
    "muzzleAddon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "muzzle" },
        "id": { "$ref": "#/$defs/id" },
        "length": { "$ref": "#/$defs/positiveNumber" },
        "width": { "$ref": "#/$defs/positiveNumber" },
        "height": { "$ref": "#/$defs/positiveNumber" },
        "z": { "$ref": "#/$defs/finiteNumber" }
      }
    },
    "occlusionMode": { "enum": ["semantic-group", "under-core", "surface-relative"] },
    "platePatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "bodyRegion": { "type": "string", "minLength": 1 },
        "size": { "$ref": "#/$defs/size" },
        "zBias": { "$ref": "#/$defs/finiteNumber" },
        "occlusionMode": { "$ref": "#/$defs/occlusionMode" },
        "occlusionReference": { "$ref": "#/$defs/id" },
        "surfaceNormal": { "$ref": "#/$defs/vector3" },
        "surfaceFrame": { "$ref": "#/$defs/surfaceFrame" },
        "planeAxes": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string", "pattern": "^[+-][xyz]$" } },
        "jointOverlap": { "$ref": "#/$defs/positiveNumber" }
      }
    },
    "surfaceFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normal", "tangent", "bitangent"],
      "properties": {
        "normal": { "$ref": "#/$defs/vector3" },
        "tangent": { "$ref": "#/$defs/vector3" },
        "bitangent": { "$ref": "#/$defs/vector3" }
      }
    },
    "anchorPatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "moduleType": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "style": { "type": "string", "minLength": 1 },
        "forward": { "type": "string", "pattern": "^[+-][xyz]$" },
        "inheritScale": { "type": "boolean" }
      }
    }
  }
}
