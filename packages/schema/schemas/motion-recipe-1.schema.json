{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:paper-rig:schema:motion-recipe-1",
  "title": "paper-rig reusable motion recipe",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "id", "clip", "phases", "blocks", "events"],
  "properties": {
    "$schema": { "const": "paper-rig/motion-recipe-1" },
    "schemaVersion": { "const": "1.0.0" },
    "id": { "$ref": "#/$defs/id" },
    "clip": { "$ref": "#/$defs/clipDefaults" },
    "phases": {
      "type": "array",
      "minItems": 4,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/phase" }
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/block" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
    "time": { "type": "number", "minimum": 0, "maximum": 1 },
    "clipDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "duration", "easing", "loop"],
      "properties": {
        "base": { "$ref": "#/$defs/id" },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "easing": { "type": "string", "minLength": 1 },
        "loop": { "type": "boolean" }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "peak", "to"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "from": { "$ref": "#/$defs/time" },
        "peak": { "$ref": "#/$defs/time" },
        "to": { "$ref": "#/$defs/time" }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "samples"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "samples": {
          "type": "object",
          "minProperties": 4,
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "name"],
      "properties": {
        "phase": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 }
      }
    }
  }
}
