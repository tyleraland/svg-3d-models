{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:paper-rig:schema:audit-manifest-1",
  "title": "paper-rig canonical audit approval manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schemaVersion", "modelId", "canonicalization", "sampling", "views"],
  "properties": {
    "schema": { "const": "paper-rig/audit-manifest/1" },
    "schemaVersion": { "const": "1.0.0" },
    "modelId": { "$ref": "#/$defs/id" },
    "canonicalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["numericPrecision", "geometryNumberFormat"],
      "properties": {
        "numericPrecision": { "const": 1e-9 },
        "geometryNumberFormat": { "const": "normalized-decimal-tokens" }
      }
    },
    "sampling": { "$ref": "#/$defs/sampling" },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/view" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
    "number": { "type": "number" },
    "vector2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/number" }
    },
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/number" }
    },
    "matrix3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/vector3" }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headingsDegrees", "elevationsDegrees", "poses"],
      "properties": {
        "headingsDegrees": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/number" } },
        "elevationsDegrees": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/number" } },
        "poses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "clip", "t"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "clip": { "$ref": "#/$defs/id" },
              "t": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "joint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "parentId", "worldPositionMeters", "localToWorldRotation", "screenPosition", "cameraDepth"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "parentId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "worldPositionMeters": { "$ref": "#/$defs/vector3" },
        "localToWorldRotation": { "$ref": "#/$defs/matrix3" },
        "screenPosition": { "$ref": "#/$defs/vector2" },
        "cameraDepth": { "$ref": "#/$defs/number" }
      }
    },
    "cameraSurfaceFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["space", "normal", "tangent", "bitangent"],
      "properties": {
        "space": { "const": "camera" },
        "normal": { "$ref": "#/$defs/vector3" },
        "tangent": { "$ref": "#/$defs/vector3" },
        "bitangent": { "$ref": "#/$defs/vector3" }
      }
    },
    "surfaceFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["space", "normal", "tangent", "bitangent", "camera"],
      "properties": {
        "space": { "const": "posed-world" },
        "normal": { "$ref": "#/$defs/vector3" },
        "tangent": { "$ref": "#/$defs/vector3" },
        "bitangent": { "$ref": "#/$defs/vector3" },
        "camera": { "$ref": "#/$defs/cameraSurfaceFrame" }
      }
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "semantic", "projection", "vector"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "semantic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sourceId", "sourceKind", "kind", "generated", "semanticRole", "bodyRegion", "side", "paletteRole", "lodTier", "depthBias"],
          "properties": {
            "sourceId": { "$ref": "#/$defs/id" },
            "sourceKind": { "enum": ["plate", "gasket"] },
            "kind": { "enum": ["plate", "gasket", "occluderCell"] },
            "generated": { "type": "boolean" },
            "semanticRole": { "type": "string", "minLength": 1 },
            "bodyRegion": { "type": "string", "minLength": 1 },
            "side": { "enum": ["left", "right", "center"] },
            "paletteRole": { "type": "string", "minLength": 1 },
            "lodTier": { "type": "string", "minLength": 1 },
            "depthBias": { "$ref": "#/$defs/number" }
          }
        },
        "projection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cameraDepth", "surfaceFrame"],
          "properties": {
            "cameraDepth": { "$ref": "#/$defs/number" },
            "surfaceFrame": { "oneOf": [{ "$ref": "#/$defs/surfaceFrame" }, { "type": "null" }] }
          }
        },
        "vector": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag", "attributes"],
          "properties": {
            "tag": { "enum": ["circle", "ellipse", "path", "rect"] },
            "attributes": {
              "type": "object",
              "required": ["id"],
              "properties": { "id": { "$ref": "#/$defs/id" } },
              "propertyNames": { "pattern": "^[A-Za-z_:][A-Za-z0-9_.:-]*$" },
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    },
    "compositingGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "semanticRole", "order", "elementIds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "semanticRole": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 0 },
        "elementIds": { "type": "array", "items": { "$ref": "#/$defs/id" } }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "poseId", "clipId", "timeNormalized", "elevationDegrees", "headingDegrees", "activeContactIds", "joints", "compositingGroups", "elements"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "poseId": { "$ref": "#/$defs/id" },
        "clipId": { "$ref": "#/$defs/id" },
        "timeNormalized": { "type": "number", "minimum": 0, "maximum": 1 },
        "elevationDegrees": { "$ref": "#/$defs/number" },
        "headingDegrees": { "$ref": "#/$defs/number" },
        "activeContactIds": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "joints": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/joint" } },
        "compositingGroups": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/compositingGroup" } },
        "elements": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/element" } }
      }
    }
  }
}
