{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:paper-rig:schema:semantic-diff-1",
  "title": "paper-rig provenance-aware semantic model diff",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schemaVersion", "baseline", "candidate", "compatible", "status", "summary", "incompatibilities", "sourceChanges", "changes"],
  "properties": {
    "schema": { "const": "paper-rig/semantic-diff/1" },
    "schemaVersion": { "const": "1.0.0" },
    "baseline": { "$ref": "#/$defs/descriptor" },
    "candidate": { "$ref": "#/$defs/descriptor" },
    "compatible": { "type": "boolean" },
    "status": { "enum": ["unchanged", "source-only", "changed", "incompatible"] },
    "summary": { "$ref": "#/$defs/summary" },
    "incompatibilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/incompatibility" }
    },
    "sourceChanges": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceChange" }
    },
    "changes": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolvedChange" }
    }
  },
  "allOf": [
    {
      "if": { "required": ["status"], "properties": { "status": { "const": "incompatible" } } },
      "then": {
        "properties": {
          "compatible": { "const": false },
          "incompatibilities": { "type": "array", "minItems": 1 },
          "sourceChanges": { "type": "array", "maxItems": 0 },
          "changes": { "type": "array", "maxItems": 0 }
        }
      },
      "else": {
        "properties": {
          "compatible": { "const": true },
          "incompatibilities": { "type": "array", "maxItems": 0 }
        }
      }
    },
    {
      "if": { "required": ["status"], "properties": { "status": { "const": "unchanged" } } },
      "then": { "properties": { "sourceChanges": { "type": "array", "maxItems": 0 }, "changes": { "type": "array", "maxItems": 0 } } }
    },
    {
      "if": { "required": ["status"], "properties": { "status": { "const": "source-only" } } },
      "then": { "properties": { "sourceChanges": { "type": "array", "minItems": 1 }, "changes": { "type": "array", "maxItems": 0 } } }
    },
    {
      "if": { "required": ["status"], "properties": { "status": { "const": "changed" } } },
      "then": { "properties": { "changes": { "type": "array", "minItems": 1 } } }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
    "nullableId": { "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
    "pointer": { "type": "string", "pattern": "^(/([^/~]|~[01])*)*$" },
    "descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceModelId", "familyId", "resolvedModelId"],
      "properties": {
        "sourceModelId": { "$ref": "#/$defs/nullableId" },
        "familyId": { "$ref": "#/$defs/nullableId" },
        "resolvedModelId": { "$ref": "#/$defs/nullableId" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceChangeCount", "resolvedChangeCount", "addedLeafCount", "removedLeafCount", "changedLeafCount", "affectedEntityCount", "unlinkedSourceChangeCount", "unlinkedResolvedChangeCount"],
      "properties": {
        "sourceChangeCount": { "type": "integer", "minimum": 0 },
        "resolvedChangeCount": { "type": "integer", "minimum": 0 },
        "addedLeafCount": { "type": "integer", "minimum": 0 },
        "removedLeafCount": { "type": "integer", "minimum": 0 },
        "changedLeafCount": { "type": "integer", "minimum": 0 },
        "affectedEntityCount": { "type": "integer", "minimum": 0 },
        "unlinkedSourceChangeCount": { "type": "integer", "minimum": 0 },
        "unlinkedResolvedChangeCount": { "type": "integer", "minimum": 0 }
      }
    },
    "incompatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^semantic-diff\\.[a-z0-9-]+$" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operation", "sourcePointer"],
      "properties": {
        "kind": { "enum": ["family", "recipe", "model-override", "derived-default"] },
        "operation": { "type": "string", "minLength": 1 },
        "sourceId": { "$ref": "#/$defs/id" },
        "sourcePointer": {
          "oneOf": [
            { "$ref": "#/$defs/pointer" },
            { "type": "null" }
          ]
        },
        "recipeId": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "family" } } },
          "then": {
            "required": ["sourceId"],
            "properties": {
              "sourceId": { "$ref": "#/$defs/id" },
              "sourcePointer": { "$ref": "#/$defs/pointer" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "recipe" } } },
          "then": {
            "required": ["recipeId"],
            "properties": {
              "recipeId": { "type": "string", "minLength": 1 },
              "sourcePointer": { "$ref": "#/$defs/pointer" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "model-override" } } },
          "then": { "properties": { "sourcePointer": { "$ref": "#/$defs/pointer" } } }
        },
        {
          "if": { "properties": { "kind": { "const": "derived-default" } } },
          "then": {
            "required": ["recipeId"],
            "properties": {
              "recipeId": { "type": "string", "minLength": 1 },
              "sourcePointer": { "type": "null" }
            }
          }
        }
      ]
    },
    "nullableOrigin": {
      "oneOf": [
        { "$ref": "#/$defs/origin" },
        { "type": "null" }
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "fieldPointer"],
      "properties": {
        "kind": { "enum": ["rig", "joint", "plate", "anchor", "clip"] },
        "id": { "$ref": "#/$defs/id" },
        "fieldPointer": { "$ref": "#/$defs/pointer" }
      }
    },
    "changeBase": {
      "type": "object",
      "required": ["kind", "baselinePresent", "candidatePresent", "before", "after"],
      "properties": {
        "kind": { "enum": ["added", "removed", "changed"] },
        "baselinePresent": { "type": "boolean" },
        "candidatePresent": { "type": "boolean" },
        "before": {},
        "after": {}
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "added" } } },
          "then": { "properties": { "baselinePresent": { "const": false }, "candidatePresent": { "const": true } } }
        },
        {
          "if": { "properties": { "kind": { "const": "removed" } } },
          "then": { "properties": { "baselinePresent": { "const": true }, "candidatePresent": { "const": false } } }
        },
        {
          "if": { "properties": { "kind": { "const": "changed" } } },
          "then": { "properties": { "baselinePresent": { "const": true }, "candidatePresent": { "const": true } } }
        }
      ]
    },
    "sourceChange": {
      "allOf": [
        { "$ref": "#/$defs/changeBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "sourcePointer", "baselinePresent", "candidatePresent", "before", "after", "affectedTargetPointers"],
          "properties": {
            "kind": { "enum": ["added", "removed", "changed"] },
            "sourcePointer": { "$ref": "#/$defs/pointer" },
            "baselinePresent": { "type": "boolean" },
            "candidatePresent": { "type": "boolean" },
            "before": {},
            "after": {},
            "affectedTargetPointers": {
              "type": "array",
              "items": { "$ref": "#/$defs/pointer" },
              "uniqueItems": true
            }
          }
        }
      ]
    },
    "resolvedChange": {
      "allOf": [
        { "$ref": "#/$defs/changeBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "targetPointer", "target", "baselinePresent", "candidatePresent", "before", "after", "baselineOrigin", "candidateOrigin", "relatedSourcePointers"],
          "properties": {
            "kind": { "enum": ["added", "removed", "changed"] },
            "targetPointer": { "$ref": "#/$defs/pointer" },
            "target": { "$ref": "#/$defs/target" },
            "baselinePresent": { "type": "boolean" },
            "candidatePresent": { "type": "boolean" },
            "before": {},
            "after": {},
            "baselineOrigin": { "$ref": "#/$defs/nullableOrigin" },
            "candidateOrigin": { "$ref": "#/$defs/nullableOrigin" },
            "relatedSourcePointers": {
              "type": "array",
              "items": { "$ref": "#/$defs/pointer" },
              "uniqueItems": true
            }
          }
        }
      ]
    }
  }
}
