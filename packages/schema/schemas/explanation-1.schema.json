{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:paper-rig:schema:explanation-1",
  "title": "paper-rig resolved field explanation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schemaVersion", "sourceModelId", "resolvedModelId", "selector", "targetPrefix", "status", "summary", "fields"],
  "properties": {
    "schema": { "const": "paper-rig/explanation/1" },
    "schemaVersion": { "const": "1.0.0" },
    "sourceModelId": { "$ref": "#/$defs/id" },
    "resolvedModelId": { "$ref": "#/$defs/id" },
    "selector": { "type": "string", "minLength": 1 },
    "targetPrefix": { "$ref": "#/$defs/pointer" },
    "status": { "enum": ["found", "not-found"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fieldCount", "overwrittenFieldCount"],
      "properties": {
        "fieldCount": { "type": "integer", "minimum": 0 },
        "overwrittenFieldCount": { "type": "integer", "minimum": 0 }
      }
    },
    "fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/field" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
    "pointer": { "type": "string", "pattern": "^(/([^/~]|~[01])*)*$" },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operation", "sourcePointer"],
      "properties": {
        "kind": { "enum": ["family", "recipe", "model-override", "derived-default"] },
        "operation": { "type": "string", "minLength": 1 },
        "sourceId": { "$ref": "#/$defs/id" },
        "sourcePointer": {
          "oneOf": [
            { "$ref": "#/$defs/pointer" },
            { "type": "null" }
          ]
        },
        "recipeId": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "family" } } },
          "then": {
            "required": ["sourceId"],
            "properties": {
              "sourceId": { "$ref": "#/$defs/id" },
              "sourcePointer": { "$ref": "#/$defs/pointer" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "recipe" } } },
          "then": {
            "required": ["recipeId"],
            "properties": {
              "recipeId": { "type": "string", "minLength": 1 },
              "sourcePointer": { "$ref": "#/$defs/pointer" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "model-override" } } },
          "then": {
            "properties": { "sourcePointer": { "$ref": "#/$defs/pointer" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "derived-default" } } },
          "then": {
            "required": ["recipeId"],
            "properties": {
              "recipeId": { "type": "string", "minLength": 1 },
              "sourcePointer": { "type": "null" }
            }
          }
        }
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "fieldPointer"],
      "properties": {
        "kind": { "enum": ["rig", "joint", "plate", "anchor", "clip"] },
        "id": { "$ref": "#/$defs/id" },
        "fieldPointer": { "$ref": "#/$defs/pointer" }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "origin", "value"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "origin": { "$ref": "#/$defs/origin" },
        "value": {}
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetPointer", "target", "value", "origin", "overwrittenWriteCount", "history"],
      "properties": {
        "targetPointer": { "$ref": "#/$defs/pointer" },
        "target": { "$ref": "#/$defs/target" },
        "value": {},
        "origin": { "$ref": "#/$defs/origin" },
        "overwrittenWriteCount": { "type": "integer", "minimum": 0 },
        "history": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/history" }
        }
      }
    }
  }
}
